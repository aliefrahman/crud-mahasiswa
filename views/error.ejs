<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Terjadi Kesalahan</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon.svg">
  <meta name="theme-color" content="#0f172a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js');
      });
    }
  </script>
  <style type="text/tailwindcss">
    @theme {
      --font-inter: 'Inter', system-ui, sans-serif;
    }
    body {
      font-family: var(--font-inter);
      background-image: radial-gradient(circle at 15% 50%, rgba(59, 130, 246, 0.15), transparent 25%),
                        radial-gradient(circle at 85% 30%, rgba(139, 92, 246, 0.15), transparent 25%);
      background-attachment: fixed;
    }
  </style>
</head>
<body class="bg-slate-900 text-slate-50 min-h-screen antialiased flex items-center justify-center p-6">
  <div class="max-w-2xl w-full">
    <main class="relative group">
      <!-- Glow effect behind card -->
      <div class="absolute -inset-1 rounded-3xl bg-gradient-to-br from-red-500/30 via-transparent to-red-900/30 opacity-100 blur-xl pointer-events-none"></div>
      
      <div class="relative bg-[#1a1f2e]/80 backdrop-blur-2xl border border-white/5 rounded-3xl p-10 sm:p-14 shadow-2xl flex flex-col items-center text-center">
        <!-- Error Icon -->
        <div class="relative mb-8 flex items-center justify-center">
          <div class="absolute inset-0 bg-red-500/20 rounded-full blur-md"></div>
          <div class="relative flex items-center justify-center w-20 h-20 rounded-full border-2 border-red-500 text-red-500 bg-red-500/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4"></path><path d="M12 16h.01"></path></svg>
          </div>
        </div>

        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white mb-4">Oops! Ada masalah.</h1>
        <p class="text-slate-400 text-lg sm:text-xl mb-10"><%= message %></p>
        
        <% if (locals.error) { %>
          <!-- Terminal/Code Mockup window -->
          <div class="w-full bg-[#0d1117] rounded-xl overflow-hidden border border-white/10 mb-10 text-left shadow-inner">
            <!-- Terminal Header -->
            <div class="bg-[#161b22] px-4 py-3 border-b border-white/5 flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
              <span class="ml-2 text-xs font-medium text-slate-500 font-mono tracking-wider items-center flex">error.log</span>
            </div>
            <!-- Terminal Body -->
            <div class="p-5 overflow-x-auto custom-scrollbar">
              <pre class="text-red-400/90 font-mono text-sm leading-relaxed"><%= JSON.stringify(error, null, 2) %></pre>
            </div>
          </div>
        <% } %>

        <div class="flex justify-center w-full">
          <a href="/" class="inline-flex items-center justify-center gap-2 px-8 py-4 w-full sm:w-auto rounded-xl font-medium text-white bg-blue-500 hover:bg-blue-400 shadow-[0_4px_20px_0_rgba(59,130,246,0.3)] hover:shadow-[0_4px_25px_0_rgba(59,130,246,0.5)] transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            Kembali ke Beranda
          </a>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
