<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Mahasiswa</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon.svg">
  <meta name="theme-color" content="#0f172a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js');
      });
    }
  </script>
  <style type="text/tailwindcss">
    @theme {
      --font-inter: 'Inter', system-ui, sans-serif;
    }
    body {
      font-family: var(--font-inter);
      background-image: radial-gradient(circle at 15% 50%, rgba(59, 130, 246, 0.15), transparent 25%),
                        radial-gradient(circle at 85% 30%, rgba(139, 92, 246, 0.15), transparent 25%);
      background-attachment: fixed;
    }
  </style>
</head>
<body class="bg-slate-900 text-slate-50 min-h-screen antialiased">
  <div class="max-w-2xl mx-auto px-6 py-12">
    <header class="flex items-center gap-6 mb-12 pb-6 border-b border-white/10">
      <a href="/" class="flex items-center justify-center w-12 h-12 rounded-full bg-white/5 text-white border border-white/10 hover:bg-white/10 hover:-translate-x-1 transition-all" title="Kembali">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <div>
        <h2 class="text-3xl font-bold tracking-tight bg-gradient-to-br from-white to-slate-400 bg-clip-text text-transparent mb-1">Tambah Mahasiswa Baru</h2>
        <p class="text-slate-400">Isi form di bawah ini dengan lengkap</p>
      </div>
    </header>

    <main class="relative group">
      <div class="absolute -inset-0.5 rounded-2xl bg-gradient-to-br from-blue-500/50 to-violet-500/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm pointer-events-none"></div>
      <div class="relative bg-slate-800/70 backdrop-blur-xl border border-white/10 rounded-2xl p-8 shadow-xl">
        <form action="/create" method="POST" class="space-y-6">
          <div>
            <label for="nim" class="block text-sm font-medium text-slate-400 mb-2">NIM</label>
            <input type="text" id="nim" name="nim" class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-500/50 transition-all" required placeholder="Contoh: 10101010">
          </div>
          
          <div>
            <label for="nama" class="block text-sm font-medium text-slate-400 mb-2">Nama Lengkap</label>
            <input type="text" id="nama" name="nama" class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-500/50 transition-all" required placeholder="Masukkan nama lengkap">
          </div>

          <div>
            <label for="jurusan" class="block text-sm font-medium text-slate-400 mb-2">Program Studi / Jurusan</label>
            <div class="relative">
              <select id="jurusan" name="jurusan" class="w-full px-4 py-3 pr-10 bg-slate-900/50 border border-white/10 rounded-xl text-white appearance-none cursor-pointer focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-500/50 transition-all" required>
                <option value="" disabled selected>Pilih Program Studi...</option>
                <option value="Teknik Informatika" class="bg-slate-800 text-white">Teknik Informatika</option>
                <option value="Sistem Informasi" class="bg-slate-800 text-white">Sistem Informasi</option>
                <option value="Manajemen Bisnis" class="bg-slate-800 text-white">Manajemen Bisnis</option>
                <option value="Akuntansi" class="bg-slate-800 text-white">Akuntansi</option>
                <option value="Desain Komunikasi Visual" class="bg-slate-800 text-white">Desain Komunikasi Visual</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-slate-400">
                <svg class="h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
              </div>
            </div>
          </div>

          <div>
            <label for="angkatan" class="block text-sm font-medium text-slate-400 mb-2">Tahun Angkatan</label>
            <input type="number" id="angkatan" name="angkatan" class="w-full px-4 py-3 bg-slate-900/50 border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-500/50 transition-all" required min="2000" max="2100" placeholder="Contoh: 2023">
          </div>

          <div class="flex items-center justify-end gap-4 pt-6 mt-6 border-t border-white/10">
            <a href="/" class="px-6 py-3 rounded-xl font-medium text-white bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">Batal</a>
            <button type="submit" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-medium text-white bg-gradient-to-br from-blue-500 to-violet-500 hover:-translate-y-0.5 shadow-[0_4px_14px_0_rgba(59,130,246,0.5)] hover:shadow-[0_6px_20px_0_rgba(139,92,246,0.4)] transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
              Simpan Data
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>
</body>
</html>
