<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Data Mahasiswa</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon.svg">
  <meta name="theme-color" content="#0f172a">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js');
      });
    }
  </script>
  <style type="text/tailwindcss">
    @theme {
      --font-inter: 'Inter', system-ui, sans-serif;
    }
    body {
      font-family: var(--font-inter);
      background-image: radial-gradient(circle at 15% 50%, rgba(59, 130, 246, 0.15), transparent 25%),
                        radial-gradient(circle at 85% 30%, rgba(139, 92, 246, 0.15), transparent 25%);
      background-attachment: fixed;
    }
  </style>
</head>
<body class="bg-slate-900 text-slate-50 min-h-screen antialiased">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-12 pb-6 border-b border-white/10 gap-6 sm:gap-0">
      <div>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight bg-gradient-to-br from-white to-slate-400 bg-clip-text text-transparent mb-1">
          Sistem Akademik
        </h1>
        <p class="text-slate-400 text-base">Manajemen Data Mahasiswa Terpadu</p>
      </div>
      <div class="flex items-center gap-3">
        <a href="/create" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-medium text-white bg-gradient-to-br from-blue-500 to-violet-500 hover:-translate-y-0.5 shadow-[0_4px_14px_0_rgba(59,130,246,0.5)] hover:shadow-[0_6px_20px_0_rgba(139,92,246,0.4)] transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
          Tambah Mahasiswa
        </a>
      </div>
    </header>

    <main class="relative group">
      <div class="absolute -inset-0.5 rounded-2xl bg-gradient-to-br from-blue-500/50 to-violet-500/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm pointer-events-none"></div>
      <div class="relative bg-slate-800/70 backdrop-blur-xl border border-white/10 rounded-2xl p-8 shadow-xl">
        <!-- Use hidden md:table for desktop, flex/grid for mobile -->
        <div class="block md:hidden space-y-4">
          <% if (mahasiswa && mahasiswa.length > 0) { %>
            <% mahasiswa.forEach((mhs) => { %>
              <div class="bg-slate-900/50 border border-white/10 rounded-xl p-5 hover:bg-white/5 transition-colors">
                <div class="flex justify-between items-start mb-4">
                  <div>
                    <strong class="text-lg font-medium text-slate-50 block mb-1"><%= mhs.nama %></strong>
                    <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20">
                      NIM: <%= mhs.nim %>
                    </span>
                  </div>
                  <div class="flex items-center gap-1 bg-slate-800 rounded-lg p-1 border border-white/5">
                    <a href="/edit/<%= mhs.id %>" class="p-1.5 rounded-md text-slate-400 hover:bg-blue-500/10 hover:text-blue-500 transition-colors" title="Edit">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                    </a>
                    <form action="/delete/<%= mhs.id %>" method="POST" class="inline-block" onsubmit="return confirm('Apakah Anda yakin ingin menghapus data <%= mhs.nama %>?');">
                      <button type="submit" class="p-1.5 rounded-md text-slate-400 hover:bg-red-500/10 hover:text-red-500 hover:shadow-[0_0_10px_rgba(239,68,68,0.4)] transition-all" title="Hapus">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                      </button>
                    </form>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-y-3 gap-x-4 text-sm">
                  <div>
                    <span class="block text-slate-500 mb-0.5">Jurusan</span>
                    <span class="text-slate-300"><%= mhs.jurusan %></span>
                  </div>
                  <div>
                    <span class="block text-slate-500 mb-0.5">Angkatan</span>
                    <span class="text-slate-300"><%= mhs.angkatan %></span>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="py-12 text-center bg-slate-900/30 border border-white/5 rounded-xl">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/5 text-slate-400 mb-4 border border-white/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
              </div>
              <h3 class="text-lg font-semibold mb-1 text-white">Belum ada data</h3>
              <p class="text-slate-400 text-sm">Silakan tambah data mahasiswa baru.</p>
            </div>
          <% } %>
        </div>

        <!-- Desktop Table View -->
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-white/10 text-slate-400 text-sm font-semibold uppercase tracking-wider">
                <th class="p-4">NIM</th>
                <th class="p-4">Nama Lengkap</th>
                <th class="p-4">Jurusan</th>
                <th class="p-4">Angkatan</th>
                <th class="p-4 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
              <% if (mahasiswa && mahasiswa.length > 0) { %>
                <% mahasiswa.forEach((mhs) => { %>
                  <tr class="transition-colors hover:bg-white/5">
                    <td class="p-4">
                      <span class="inline-block px-3 py-1 rounded-full text-sm font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20">
                        <%= mhs.nim %>
                      </span>
                    </td>
                    <td class="p-4"><strong class="font-medium text-slate-50"><%= mhs.nama %></strong></td>
                    <td class="p-4 text-slate-300"><%= mhs.jurusan %></td>
                    <td class="p-4 text-slate-300"><%= mhs.angkatan %></td>
                    <td class="p-4">
                      <div class="flex items-center justify-end gap-2">
                        <a href="/edit/<%= mhs.id %>" class="p-2 rounded-lg text-slate-400 hover:bg-blue-500/10 hover:text-blue-500 transition-colors" title="Edit">
                          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                        </a>
                        <form action="/delete/<%= mhs.id %>" method="POST" class="inline-block" onsubmit="return confirm('Apakah Anda yakin ingin menghapus data <%= mhs.nama %>?');">
                          <button type="submit" class="p-2 rounded-lg text-slate-400 hover:bg-red-500/10 hover:text-red-500 hover:shadow-[0_0_10px_rgba(239,68,68,0.4)] transition-all" title="Hapus">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="py-16 text-center">
                    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/5 text-slate-400 mb-6 border border-white/10">
                      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    </div>
                    <h3 class="text-xl font-semibold mb-2 text-white">Belum ada data</h3>
                    <p class="text-slate-400">Silakan tambah data mahasiswa baru.</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <script>
    let deferredPrompt;
    const installAppBtn = document.getElementById('installAppBtn');

    window.addEventListener('beforeinstallprompt', (e) => {
      // Prevent the mini-infobar from appearing on mobile
      e.preventDefault();
      // Stash the event so it can be triggered later.
      deferredPrompt = e;
      // Update UI notify the user they can install the PWA
      if (installAppBtn) installAppBtn.classList.remove('hidden');
    });

    if (installAppBtn) {
      installAppBtn.addEventListener('click', async () => {
        if (!deferredPrompt) return;
        // Show the install prompt
        deferredPrompt.prompt();
        // Wait for the user to respond to the prompt
        const { outcome } = await deferredPrompt.userChoice;
        if (outcome === 'accepted') {
          console.log('User accepted the install prompt');
        } else {
          console.log('User dismissed the install prompt');
        }
        // We've used the prompt, and can't use it again, throw it away
        deferredPrompt = null;
        installAppBtn.classList.add('hidden');
      });
    }

    window.addEventListener('appinstalled', (evt) => {
      // Log install to analytics
      console.log('INSTALL: Success');
      if (installAppBtn) installAppBtn.classList.add('hidden');
    });
  </script>
</body>
</html>
